{
  "mcpServers": {
    "wallet": {
      "command": "node",
      "args": ["/ABSOLUTE/PATH/to/wallet-mcp/apps/wallet-mcp/dist/index.js"],
      "env": {
        "TRANSPORTER_URL": "http://localhost:8787",
        "STELLAR_NETWORK": "stellar:testnet",

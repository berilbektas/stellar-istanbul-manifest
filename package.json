{
  "name": "wallet-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Wallet MCP — a remote signer for agentic payments. Agents ask, you approve, and your keys never leave your wallet.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/wallet-mcp",
    "apps/transporter",
    "apps/twitter-backend",
    "apps/twitter-mcp"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "biome check --write --formatter-enabled=true --assist-enabled=true ",
    "clean": "turbo clean && rm -rf node_modules && rm -rf bun.lock",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "freighter:install": "cd apps/freighter && yarn install",
    "freighter:build": "cd apps/freighter && yarn build:extension:production"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@changesets/cli": "^2.29.8",
    "@commitlint/cli": "^20.4.0",
    "@commitlint/config-conventional": "^20.4.0",
    "@types/bun": "^1.3.8",
    "husky": "^9.1.7",
    "turbo": "^2.8.0",
    "typescript": "^5.9.3"
  }
}

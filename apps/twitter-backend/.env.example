# Mock Twitter backend — x402 resource server (manifest §8, §12, §14)

PORT=4021

# Stellar network + Soroban RPC (manifest §14)
STELLAR_NETWORK=stellar:testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Facilitator: Coinbase testnet (no API key) is simplest.
# OpenZeppelin / Built-on-Stellar needs a Relayer API key (Bearer).
FACILITATOR_URL=https://www.x402.org/facilitator
# FACILITATOR_API_KEY=

# Where payments settle to (your testnet G-address with a USDC trustline)
PAY_TO=G...

# Paid resource price (POST /tweet)
PRICE_ASSET=USDC
PRICE_AMOUNT=0.01

# Twitter backend — x402 resource server (gerçek Twitter API v2, hepsi ücretli)

PORT=4021

# x402 BYPASS (yalnızca dev/test): true ise ödeme middleware'i hiç mount edilmez,
# tüm endpoint'ler 402'siz/ücretsiz çalışır. Bypass açıkken PAY_TO da gerekmez.
# PROD'DA ASLA "true" YAPMA.
X402_BYPASS=true

# Stellar network (manifest §14)
STELLAR_NETWORK=stellar:testnet

# Facilitator: Coinbase testnet (no API key) is simplest.
# OpenZeppelin / Built-on-Stellar needs a Relayer API key (Bearer).
FACILITATOR_URL=https://www.x402.org/facilitator

# Ödemelerin gideceği testnet G-adresi (USDC trustline açık olmalı)
PAY_TO=G...

# Fiyatlar per-operation, registry'de tanımlı (X pay-per-use) — burada PRICE yok.

# --- Twitter / X API v2 (OAuth 1.0a user-context) ---
TWITTER_APP_KEY=
TWITTER_APP_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

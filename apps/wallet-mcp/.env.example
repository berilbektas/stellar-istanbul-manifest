# Wallet MCP — agent-host config (manifest §5)
# Only the transporter URL belongs in config. The JWT is written to
# ~/.wallet-mcp/creds.json after pairing (so the MCP need not be restarted).

TRANSPORTER_URL=http://localhost:8787

# Stellar network + Soroban RPC (manifest §14)
STELLAR_NETWORK=stellar:testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

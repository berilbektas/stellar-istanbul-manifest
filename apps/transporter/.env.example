# Transporter config (manifest §5, §9, §18)

PORT=8787

# JWT signing key (manifest §6 — sensitive; SEV-SNP-protected).
# In production this is generated at boot inside the TEE. For LOCAL dev only,
# set a static value here. NEVER commit a real key.
JWT_SIGNING_KEY=dev-only-change-me

# TOTP validation window (steps of 30s tolerated either side)
TOTP_WINDOW=1

# Pending sign-request timeout (ms) — must cover human approval (manifest §7, §15)
SIGN_REQUEST_TTL_MS=90000

# TEE / attestation (manifest §18). Path to the snpguest binary on the VM.
SNPGUEST_BIN=/usr/local/bin/snpguest

{
  "name": "@wallet-mcp/transporter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Transporter — pure relay + pairing authority + attestation, runs inside an AWS AMD SEV-SNP confidential VM. Holds no private key.",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "otplib": "^12.0.1",
    "web-push": "^3.6.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.5",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
